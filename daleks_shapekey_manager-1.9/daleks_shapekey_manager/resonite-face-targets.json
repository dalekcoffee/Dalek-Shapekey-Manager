{
  "schemaVersion": "1.0",
  "description": "Blendshape targets for Resonite DirectVisemeDriver, EyeLinearDriver, and AvatarExpressionDriver. Viseme matching is documented and deterministic; eye and expression detection is an undocumented heuristic, so ARKit/Unified Expressions naming is the de-facto compatibility target.",
  "visemes": {
    "authority": "documented",
    "matching": {
      "caseInsensitive": true,
      "segmentSplit": "split name on any non-letter character into segments",
      "match": "viseme matches if any segment contains one of its tokens (substring)",
      "priority": "any candidate whose name contains the 'vrc' prefix wins over all others for that viseme",
      "rerunInGame": "Auto-assign targets button on DirectVisemeDriver"
    },
    "targets": [
      { "viseme": "Silence", "tokens": ["silence", "sil"], "ideal": "vrc.v_sil" },
      { "viseme": "PP", "tokens": ["pp", "p"], "ideal": "vrc.v_pp" },
      { "viseme": "FF", "tokens": ["f", "ff", "fv"], "ideal": "vrc.v_ff" },
      { "viseme": "TH", "tokens": ["th", "h"], "ideal": "vrc.v_th" },
      { "viseme": "DD", "tokens": ["d", "td", "dd"], "ideal": "vrc.v_dd" },
      { "viseme": "KK", "tokens": ["kk", "k"], "ideal": "vrc.v_kk" },
      { "viseme": "CH", "tokens": ["ch", "sh"], "ideal": "vrc.v_ch" },
      { "viseme": "SS", "tokens": ["ss", "s"], "ideal": "vrc.v_ss" },
      { "viseme": "NN", "tokens": ["nn", "n", "\u3093"], "ideal": "vrc.v_nn" },
      { "viseme": "RR", "tokens": ["rr", "r"], "ideal": "vrc.v_rr" },
      { "viseme": "AA", "tokens": ["aa", "a", "ah", "\u3042"], "ideal": "vrc.v_aa" },
      { "viseme": "E", "tokens": ["e", "ee", "\u3048"], "ideal": "vrc.v_e" },
      { "viseme": "IH", "tokens": ["ih", "\u3044"], "ideal": "vrc.v_ih" },
      { "viseme": "OH", "tokens": ["o", "oh", "oo", "uh", "\u304a"], "ideal": "vrc.v_oh" },
      { "viseme": "OU", "tokens": ["ou", "u", "\u3046"], "ideal": "vrc.v_ou" }
    ],
    "notes": "Single-letter tokens collide aggressively under substring matching; tie-break beyond vrc-priority is unspecified. Normalize to vrc.v_<token> in the fix pass."
  },
  "eyes": {
    "authority": "heuristic-undocumented",
    "perSide": ["Left", "Right"],
    "targets": [
      { "slot": "OpenCloseTarget", "meaning": "blink / eye closed", "suggested": ["eyeBlinkLeft", "eyeBlinkRight", "EyeClosedLeft", "EyeClosedRight"] },
      { "slot": "WidenTarget", "meaning": "eye wide / surprise", "suggested": ["eyeWideLeft", "eyeWideRight"] },
      { "slot": "SqueezeTarget", "meaning": "squint", "suggested": ["eyeSquintLeft", "eyeSquintRight"] },
      { "slot": "FrownTarget", "meaning": "eye-area frown", "suggested": [] },
      { "slot": "PupilSizeTarget", "meaning": "pupil dilation (usually a driven value, not a blendshape)", "suggested": [] },
      { "slot": "InnerBrowRaiseTarget", "meaning": "inner brow up", "suggested": ["browInnerUp", "BrowInnerUpLeft", "BrowInnerUpRight"] },
      { "slot": "InnerBrowLowerTarget", "meaning": "inner brow down", "suggested": ["browDownLeft", "browDownRight"] },
      { "slot": "OuterBrowRaiseTarget", "meaning": "outer brow up", "suggested": ["browOuterUpLeft", "browOuterUpRight"] },
      { "slot": "OuterBrowLowerTarget", "meaning": "outer brow down", "suggested": [] },
      { "slot": "LookLeft", "meaning": "eye-surface look shift (needs projection plane)", "suggested": [] },
      { "slot": "LookUp", "meaning": "eye-surface look shift (needs projection plane)", "suggested": [] },
      { "slot": "LookRight", "meaning": "eye-surface look shift (needs projection plane)", "suggested": [] },
      { "slot": "LookDown", "meaning": "eye-surface look shift (needs projection plane)", "suggested": [] }
    ]
  },
